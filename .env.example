# ============================================
# Headshot Studio - Environment Variables
# ============================================

# Database (Neon Serverless PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/headshot_studio?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secure-random-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Node Environment
NODE_ENV=development

# AWS / SST (for Lambda deployment)
# AWS_REGION=us-east-1
# APP_DOMAIN=headshot.example.com

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
